        {
          "name": "Create Payment - Idempotency Conflict",
          "request": {
            "description": "Run the success request first with conflictIdempotencyKey as the Idempotency-Key, then run this request with the same key and a different body.",
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{jwtToken}}"
              },
              {
                "key": "Idempotency-Key",
                "value": "{{conflictIdempotencyKey}}"
              },
              {
                "key": "X-Correlation-ID",
                "value": "{{correlationId}}"
