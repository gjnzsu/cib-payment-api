{
  "info": {
    "_postman_id": "5c58fd8a-0d39-40d3-b9e8-6e07df0d3e2f",
    "name": "Domestic RTP Payment Service API",
    "description": "Postman collection for the CreateDomesticPayment and GetDomesticPaymentStatus API flows. The collection aligns with the OpenAPI PaymentResponse, PaymentStatusResponse, ErrorResponse, and local/test-only X-Mock-Scenario behavior.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{jwtToken}}",
        "type": "string"
      }
    ]
  },
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "if (!pm.environment.get('idempotencyKey')) {",
          "  pm.environment.set('idempotencyKey', 'postman-' + pm.variables.replaceIn('{{$guid}}'));",
          "}",
          "if (!pm.environment.get('correlationId')) {",
          "  pm.environment.set('correlationId', 'postman-' + pm.variables.replaceIn('{{$guid}}'));",
          "}"
        ]
      }
    }
  ],
  "item": [
    {
      "name": "Happy Path",
      "item": [
        {
          "name": "Create Payment - Success",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{jwtToken}}"
              },
              {
                "key": "Idempotency-Key",
                "value": "{{idempotencyKey}}"
              },
              {
                "key": "X-Correlation-ID",
                "value": "{{correlationId}}"
              },
              {
                "key": "X-Mock-Scenario",
                "value": "{{mockScenario}}",
                "description": "Local/test-only downstream scenario selector. Not part of production payment semantics."
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"debtorAccount\": {\n    \"bankCode\": \"CIBBMYKL\",\n    \"accountNumber\": \"1234567890\",\n    \"accountName\": \"Acme Treasury\"\n  },\n  \"creditorAccount\": {\n    \"bankCode\": \"PAYBMYKL\",\n    \"accountNumber\": \"9876543210\",\n    \"accountName\": \"Supplier Sdn Bhd\"\n  },\n  \"amount\": {\n    \"currency\": \"MYR\",\n    \"value\": \"1250.50\"\n  },\n  \"paymentReference\": \"INV-2026-SUCCESS\",\n  \"remittanceInformation\": \"Successful mock payment\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/v1/domestic-payments",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "v1",
                "domestic-payments"
              ]
            }
          },
          "response": [
            {
              "name": "202 Accepted - Success",
              "originalRequest": {
                "method": "POST",
                "header": [],
                "url": {
                  "raw": "{{baseUrl}}/v1/domestic-payments",
                  "host": [
                    "{{baseUrl}}"
                  ],
                  "path": [
                    "v1",
                    "domestic-payments"
                  ]
                }
              },
              "status": "Accepted",
              "code": 202,
              "_postman_previewlanguage": "json",
              "header": [
                {
                  "key": "X-Correlation-ID",
                  "value": "{{correlationId}}"
                }
              ],
              "body": "{\n  \"paymentId\": \"7e9d1180-14c9-4498-85ec-4f4c1238d532\",\n  \"status\": \"ACCEPTED\",\n  \"createdAt\": \"2026-05-09T08:00:00Z\",\n  \"updatedAt\": \"2026-05-09T08:00:00Z\",\n  \"correlationId\": \"postman-local-correlation-001\",\n  \"links\": {\n    \"status\": \"/v1/domestic-payments/7e9d1180-14c9-4498-85ec-4f4c1238d532\"\n  }\n}"
            }
          ],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('payment creation is accepted', function () {",
                  "  pm.response.to.have.status(202);",
                  "});",
                  "const body = pm.response.json();",
                  "if (body.paymentId) {",
                  "  pm.environment.set('paymentId', body.paymentId);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Get Payment Status",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{jwtToken}}"
              },
              {
                "key": "X-Correlation-ID",
                "value": "{{correlationId}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/v1/domestic-payments/{{paymentId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "v1",
                "domestic-payments",
                "{{paymentId}}"
              ]
            }
          },
          "response": [
            {
              "name": "200 OK - Status Query",
              "originalRequest": {
                "method": "GET",
                "header": [],
                "url": {
                  "raw": "{{baseUrl}}/v1/domestic-payments/{{paymentId}}",
                  "host": [
                    "{{baseUrl}}"
                  ],
                  "path": [
                    "v1",
                    "domestic-payments",
                    "{{paymentId}}"
                  ]
                }
              },
              "status": "OK",
              "code": 200,
              "_postman_previewlanguage": "json",
              "body": "{\n  \"paymentId\": \"7e9d1180-14c9-4498-85ec-4f4c1238d532\",\n  \"status\": \"COMPLETED\",\n  \"createdAt\": \"2026-05-09T08:00:00Z\",\n  \"updatedAt\": \"2026-05-09T08:00:01Z\",\n  \"correlationId\": \"postman-local-correlation-001\",\n  \"links\": {\n    \"self\": \"/v1/domestic-payments/7e9d1180-14c9-4498-85ec-4f4c1238d532\"\n  }\n}"
            }
          ]
        }
      ]
    },
