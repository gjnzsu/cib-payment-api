          "response": [
            {
              "name": "403 Forbidden - Authorization",
              "status": "Forbidden",
              "code": 403,
              "_postman_previewlanguage": "json",
              "body": "{\n  \"code\": \"FORBIDDEN\",\n  \"message\": \"Authenticated client lacks the required scope\",\n  \"status\": 403,\n  \"correlationId\": \"postman-local-correlation-001\"\n}"
            }
          ],
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const readOnlyJwtToken = pm.environment.get('readOnlyJwtToken');",
                  "if (!readOnlyJwtToken || readOnlyJwtToken.includes('replace-with-local-jwt')) {",
                  "  throw new Error('Set readOnlyJwtToken to a JWT generated with only payments:read before running this request.');",
                  "}",
                  "const payload = JSON.parse(atob(readOnlyJwtToken.split('.')[1].replace(/-/g, '+').replace(/_/g, '/')));",
                  "const scope = payload.scope || '';",
                  "if (scope.includes('payments:create')) {",
                  "  throw new Error('readOnlyJwtToken must not include payments:create. Regenerate it with only payments:read.');",
                  "}",
                  "if (!scope.includes('payments:read')) {",
                  "  throw new Error('readOnlyJwtToken must include payments:read.');",
                  "}",
                  "pm.request.headers.upsert({key: 'Authorization', value: 'Bearer ' + readOnlyJwtToken});"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('authorization failure returns forbidden', function () {",
                  "  pm.response.to.have.status(403);",
                  "  const body = pm.response.json();",
                  "  pm.expect(body.code).to.eql('FORBIDDEN');",
                  "  pm.expect(body.status).to.eql(403);",
                  "  pm.expect(body.correlationId).to.eql(pm.environment.get('correlationId'));",
                  "});"
                ]
              }
            }
          ]
        },
