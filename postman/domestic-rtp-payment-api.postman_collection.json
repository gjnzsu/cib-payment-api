{
  "info": {
    "_postman_id": "5c58fd8a-0d39-40d3-b9e8-6e07df0d3e2f",
    "name": "Domestic RTP Payment Service API",
    "description": "Postman collection for ISO-native CreateDomesticPayment and GetDomesticPaymentStatus API flows. Uses pain.001.001.09 requests and pain.002.001.10 responses. The HK clearing and settlement behavior is simulator-only. pacs.008 is internal only. Allowed X-Mock-Scenario values: success, rejection, suspicious_proxy_or_account, pending, timeout, internal_failure.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "if (!pm.environment.get('idempotencyKey')) {",
          "  pm.environment.set('idempotencyKey', 'postman-' + pm.variables.replaceIn('{{$guid}}'));",
          "}",
          "if (!pm.environment.get('correlationId')) {",
          "  pm.environment.set('correlationId', 'postman-' + pm.variables.replaceIn('{{$guid}}'));",
          "}"
        ]
      }
    }
  ],
  "item": [
    {
      "name": "ISO Happy Path",
      "item": [
        {
          "name": "Create Payment - Success",
          "request": {
            "method": "POST",
            "header": [
              {"key": "Authorization", "value": "Bearer {{jwtToken}}"},
              {"key": "Idempotency-Key", "value": "{{idempotencyKey}}"},
              {"key": "X-Correlation-ID", "value": "{{correlationId}}"},
              {"key": "X-Mock-Scenario", "value": "{{mockScenario}}"},
              {"key": "Content-Type", "value": "application/pain.001+xml"},
              {"key": "Accept", "value": "application/pain.002+xml"}
            ],
            "body": {"mode": "raw", "raw": "<?xml version=\"1.0\" encoding=\"UTF-8\"?>\n<Document xmlns=\"urn:iso:std:iso:20022:tech:xsd:pain.001.001.09\">\n  <CstmrCdtTrfInitn>\n    <GrpHdr><MsgId>MSG-20260524-0001</MsgId><CreDtTm>2026-05-24T10:00:00+08:00</CreDtTm><NbOfTxs>1</NbOfTxs></GrpHdr>\n    <PmtInf>\n      <PmtInfId>PMT-20260524-SUCCESS</PmtInfId><PmtMtd>TRF</PmtMtd>\n      <Dbtr><Nm>Acme Treasury HK</Nm></Dbtr>\n      <DbtrAcct><Id><Othr><Id>000111222333</Id></Othr></Id></DbtrAcct>\n      <CdtTrfTxInf>\n        <PmtId><InstrId>INSTR-20260524-0001</InstrId><EndToEndId>INV-2026-0001</EndToEndId></PmtId>\n        <Amt><InstdAmt Ccy=\"HKD\">1250.50</InstdAmt></Amt>\n        <Cdtr><Nm>Supplier HK Limited</Nm></Cdtr>\n        <CdtrAcct><Id><Othr><Id>000123456789</Id></Othr></Id></CdtrAcct>\n        <RmtInf><Ustrd>Invoice INV-2026-0001 supplier settlement</Ustrd><Strd><CdtrRefInf><Ref>SCREF-2026-0001</Ref></CdtrRefInf></Strd></RmtInf>\n      </CdtTrfTxInf>\n    </PmtInf>\n  </CstmrCdtTrfInitn>\n</Document>"},
            "url": {"raw": "{{baseUrl}}/v1/domestic-payments", "host": ["{{baseUrl}}"], "path": ["v1", "domestic-payments"]}
          },
          "response": [
            {
              "name": "200 OK - ACSC",
              "status": "OK",
              "code": 200,
              "_postman_previewlanguage": "xml",
              "header": [{"key": "Content-Type", "value": "application/pain.002+xml"}],
              "body": "<?xml version=\"1.0\" encoding=\"UTF-8\"?><Document xmlns=\"urn:iso:std:iso:20022:tech:xsd:pain.002.001.10\"><CstmrPmtStsRpt><OrgnlPmtInfAndSts><TxInfAndSts><OrgnlEndToEndId>INV-2026-0001</OrgnlEndToEndId><TxSts>ACSC</TxSts></TxInfAndSts></OrgnlPmtInfAndSts></CstmrPmtStsRpt></Document>"
            }
          ],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('payment creation returns pain.002 ACSC', function () {",
                  "  pm.response.to.have.status(200);",
                  "  pm.expect(pm.response.text()).to.include('pain.002.001.10');",
                  "  pm.expect(pm.response.text()).to.include('<TxSts>ACSC</TxSts>');",
                  "});",
                  "const paymentId = pm.response.text().match(/[0-9a-fA-F-]{36}/);",
                  "if (paymentId) { pm.environment.set('paymentId', paymentId[0]); }"
                ]
              }
            }
          ]
        },
        {
          "name": "Get Payment Status",
          "request": {
            "method": "GET",
            "header": [
              {"key": "Authorization", "value": "Bearer {{jwtToken}}"},
              {"key": "X-Correlation-ID", "value": "{{correlationId}}"},
              {"key": "Accept", "value": "application/pain.002+xml"}
            ],
            "url": {"raw": "{{baseUrl}}/v1/domestic-payments/{{paymentId}}", "host": ["{{baseUrl}}"], "path": ["v1", "domestic-payments", "{{paymentId}}"]}
          },
          "response": [
            {
              "name": "200 OK - Status Query ACSC",
              "status": "OK",
              "code": 200,
              "_postman_previewlanguage": "xml",
              "body": "<?xml version=\"1.0\" encoding=\"UTF-8\"?><Document xmlns=\"urn:iso:std:iso:20022:tech:xsd:pain.002.001.10\"><CstmrPmtStsRpt><OrgnlPmtInfAndSts><TxInfAndSts><OrgnlEndToEndId>INV-2026-0001</OrgnlEndToEndId><TxSts>ACSC</TxSts></TxInfAndSts></OrgnlPmtInfAndSts></CstmrPmtStsRpt></Document>"
            }
          ]
        }
      ]
    },
