{
  "info": {
    "_postman_id": "5c58fd8a-0d39-40d3-b9e8-6e07df0d3e2f",
    "name": "Domestic RTP Payment Service API",
    "description": "Postman collection for the CreateDomesticPayment and GetDomesticPaymentStatus API flows. The collection aligns with the OpenAPI PaymentResponse, PaymentStatusResponse, ErrorResponse, and local/test-only X-Mock-Scenario behavior. Allowed mock values: success, rejection, timeout, internal_failure.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "if (!pm.environment.get('idempotencyKey')) {",
          "  pm.environment.set('idempotencyKey', 'postman-' + pm.variables.replaceIn('{{$guid}}'));",
          "}",
          "if (!pm.environment.get('correlationId')) {",
          "  pm.environment.set('correlationId', 'postman-' + pm.variables.replaceIn('{{$guid}}'));",
          "}"
        ]
      }
    }
  ],
