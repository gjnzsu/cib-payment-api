          "response": [{"name": "200 OK - PDNG Timeout Scenario", "status": "OK", "code": 200, "_postman_previewlanguage": "xml", "body": "<?xml version=\"1.0\"?><Document xmlns=\"urn:iso:std:iso:20022:tech:xsd:pain.002.001.10\"><CstmrPmtStsRpt><OrgnlPmtInfAndSts><TxInfAndSts><TxSts>PDNG</TxSts></TxInfAndSts></OrgnlPmtInfAndSts></CstmrPmtStsRpt></Document>"}],
          "event": [{"listen": "test", "script": {"type": "text/javascript", "exec": ["pm.test('ISO status is PDNG', function () { pm.expect(pm.response.text()).to.include('<TxSts>PDNG</TxSts>'); });"]}}]
        },
