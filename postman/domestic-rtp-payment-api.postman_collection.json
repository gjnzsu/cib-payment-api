    {
      "name": "Error And Idempotency Scenarios",
      "item": [
        {
          "name": "Create Payment - Malformed XML",
          "request": {
            "method": "POST",
            "header": [
              {"key": "Authorization", "value": "Bearer {{jwtToken}}"},
              {"key": "Idempotency-Key", "value": "postman-malformed-{{$guid}}"},
              {"key": "X-Correlation-ID", "value": "{{correlationId}}"},
              {"key": "Content-Type", "value": "application/pain.001+xml"}
            ],
            "body": {"mode": "raw", "raw": "<Document><broken></Document>"},
            "url": {"raw": "{{baseUrl}}/v1/domestic-payments", "host": ["{{baseUrl}}"], "path": ["v1", "domestic-payments"]}
          },
          "response": [{"name": "400 Bad Request - Validation", "status": "Bad Request", "code": 400, "_postman_previewlanguage": "json", "body": "{\"code\":\"VALIDATION_ERROR\",\"message\":\"Request validation failed\",\"status\":400,\"correlationId\":\"postman-local-correlation-001\"}"}],
          "event": [{"listen": "test", "script": {"type": "text/javascript", "exec": ["pm.test('malformed XML returns validation error', function () {", "  pm.response.to.have.status(400);", "  const body = pm.response.json();", "  pm.expect(body.code).to.eql('VALIDATION_ERROR');", "});"]}}]
        },
        {
          "name": "Create Payment - Non-HKD Profile Failure",
          "request": {
            "method": "POST",
            "header": [
              {"key": "Authorization", "value": "Bearer {{jwtToken}}"},
              {"key": "Idempotency-Key", "value": "postman-non-hkd-{{$guid}}"},
              {"key": "X-Correlation-ID", "value": "{{correlationId}}"},
              {"key": "Content-Type", "value": "application/pain.001+xml"}
            ],
            "body": {"mode": "raw", "raw": "<?xml version=\"1.0\"?><Document xmlns=\"urn:iso:std:iso:20022:tech:xsd:pain.001.001.09\"><CstmrCdtTrfInitn><GrpHdr><MsgId>MSG-20260524-NONHKD</MsgId><NbOfTxs>1</NbOfTxs></GrpHdr><PmtInf><PmtInfId>PMT-20260524-NONHKD</PmtInfId><CdtTrfTxInf><PmtId><InstrId>INSTR-20260524-NONHKD</InstrId><EndToEndId>INV-2026-NONHKD</EndToEndId></PmtId><Amt><InstdAmt Ccy=\"USD\">50.00</InstdAmt></Amt><Cdtr><Nm>Supplier HK Limited</Nm></Cdtr><CdtrAcct><Id><Othr><Id>000123456789</Id></Othr></Id></CdtrAcct></CdtTrfTxInf></PmtInf></CstmrCdtTrfInitn></Document>"},
            "url": {"raw": "{{baseUrl}}/v1/domestic-payments", "host": ["{{baseUrl}}"], "path": ["v1", "domestic-payments"]}
          },
          "response": [{"name": "422 Unprocessable Entity - HK Profile", "status": "Unprocessable Entity", "code": 422, "_postman_previewlanguage": "json", "body": "{\"code\":\"SEMANTIC_ERROR\",\"message\":\"Payment instruction is semantically invalid\",\"status\":422,\"correlationId\":\"postman-local-correlation-001\"}"}],
          "event": [{"listen": "test", "script": {"type": "text/javascript", "exec": ["pm.test('non-HKD profile failure returns semantic error', function () {", "  pm.response.to.have.status(422);", "});"]}}]
        },
        {
          "name": "Create Payment - Replay",
          "request": {
            "description": "Run after Create Payment - Success with the same Idempotency-Key and same normalized pain.001 semantics. The API returns the original pain.002.",
            "method": "POST",
            "header": [
              {"key": "Authorization", "value": "Bearer {{jwtToken}}"},
              {"key": "Idempotency-Key", "value": "{{idempotencyKey}}"},
              {"key": "X-Correlation-ID", "value": "{{correlationId}}"},
              {"key": "X-Mock-Scenario", "value": "{{mockScenario}}"},
              {"key": "Content-Type", "value": "application/pain.001+xml"}
            ],
            "body": {"mode": "raw", "raw": "<?xml version=\"1.0\" encoding=\"UTF-8\"?><Document xmlns=\"urn:iso:std:iso:20022:tech:xsd:pain.001.001.09\"><CstmrCdtTrfInitn><GrpHdr><MsgId>MSG-20260524-0001</MsgId><NbOfTxs>1</NbOfTxs></GrpHdr><PmtInf><PmtInfId>PMT-20260524-SUCCESS</PmtInfId><CdtTrfTxInf><PmtId><InstrId>INSTR-20260524-0001</InstrId><EndToEndId>INV-2026-0001</EndToEndId></PmtId><Amt><InstdAmt Ccy=\"HKD\">1250.50</InstdAmt></Amt><Cdtr><Nm>Supplier HK Limited</Nm></Cdtr><CdtrAcct><Id><Othr><Id>000123456789</Id></Othr></Id></CdtrAcct><RmtInf><Ustrd>Invoice INV-2026-0001 supplier settlement</Ustrd><Strd><CdtrRefInf><Ref>SCREF-2026-0001</Ref></CdtrRefInf></Strd></RmtInf></CdtTrfTxInf></PmtInf></CstmrCdtTrfInitn></Document>"},
            "url": {"raw": "{{baseUrl}}/v1/domestic-payments", "host": ["{{baseUrl}}"], "path": ["v1", "domestic-payments"]}
          },
          "event": [{"listen": "test", "script": {"type": "text/javascript", "exec": ["pm.test('idempotent replay returns the original pain.002', function () {", "  pm.response.to.have.status(200);", "  pm.expect(pm.response.text()).to.include('pain.002.001.10');", "});"]}}]
        },
        {
          "name": "Create Payment - Authentication Failure",
          "auth": {"type": "bearer", "bearer": [{"key": "token", "value": "invalid-local-test-token", "type": "string"}]},
          "request": {
            "method": "POST",
            "header": [
              {"key": "Authorization", "value": "Bearer invalid-local-test-token"},
              {"key": "Idempotency-Key", "value": "postman-authentication-failure-{{$guid}}"},
              {"key": "X-Correlation-ID", "value": "{{correlationId}}"},
              {"key": "Content-Type", "value": "application/pain.001+xml"}
            ],
            "body": {"mode": "raw", "raw": "<?xml version=\"1.0\"?><Document xmlns=\"urn:iso:std:iso:20022:tech:xsd:pain.001.001.09\"/>"},
            "url": {"raw": "{{baseUrl}}/v1/domestic-payments", "host": ["{{baseUrl}}"], "path": ["v1", "domestic-payments"]}
          },
          "response": [{"name": "401 Unauthorized - Authentication", "status": "Unauthorized", "code": 401, "_postman_previewlanguage": "json", "body": "{\"code\":\"UNAUTHORIZED\",\"message\":\"Authentication is required or invalid\",\"status\":401,\"correlationId\":\"postman-local-correlation-001\"}"}],
          "event": [{"listen": "prerequest", "script": {"type": "text/javascript", "exec": ["pm.request.headers.upsert({key: 'Authorization', value: 'Bearer invalid-local-test-token'});"]}}, {"listen": "test", "script": {"type": "text/javascript", "exec": ["pm.test('authentication failure returns unauthorized', function () { pm.response.to.have.status(401); });"]}}]
        },
        {
          "name": "Create Payment - Authorization Failure",
          "auth": {"type": "bearer", "bearer": [{"key": "token", "value": "{{readOnlyJwtToken}}", "type": "string"}]},
          "request": {
            "method": "POST",
            "header": [
              {"key": "Authorization", "value": "Bearer {{readOnlyJwtToken}}"},
              {"key": "Idempotency-Key", "value": "postman-authorization-failure-{{$guid}}"},
              {"key": "X-Correlation-ID", "value": "{{correlationId}}"},
              {"key": "Content-Type", "value": "application/pain.001+xml"}
            ],
            "body": {"mode": "raw", "raw": "<?xml version=\"1.0\"?><Document xmlns=\"urn:iso:std:iso:20022:tech:xsd:pain.001.001.09\"/>"},
            "url": {"raw": "{{baseUrl}}/v1/domestic-payments", "host": ["{{baseUrl}}"], "path": ["v1", "domestic-payments"]}
          },
          "response": [{"name": "403 Forbidden - Authorization", "status": "Forbidden", "code": 403, "_postman_previewlanguage": "json", "body": "{\"code\":\"FORBIDDEN\",\"message\":\"Authenticated client lacks the required scope\",\"status\":403,\"correlationId\":\"postman-local-correlation-001\"}"}],
          "event": [{"listen": "prerequest", "script": {"type": "text/javascript", "exec": ["const readOnlyJwtToken = pm.environment.get('readOnlyJwtToken');", "if (!readOnlyJwtToken || readOnlyJwtToken.includes('replace-with-local-jwt')) {", "  throw new Error('Set readOnlyJwtToken to a JWT generated with only payments:read before running this request.');", "}", "const payload = JSON.parse(atob(readOnlyJwtToken.split('.')[1].replace(/-/g, '+').replace(/_/g, '/')));", "const scope = payload.scope || '';", "if (scope.includes('payments:create')) {", "  throw new Error('readOnlyJwtToken must not include payments:create. Regenerate it with only payments:read.');", "}", "if (!scope.includes('payments:read')) {", "  throw new Error('readOnlyJwtToken must include payments:read.');", "}", "pm.request.headers.upsert({key: 'Authorization', value: 'Bearer ' + readOnlyJwtToken});"]}}, {"listen": "test", "script": {"type": "text/javascript", "exec": ["pm.test('authorization failure returns forbidden', function () { pm.response.to.have.status(403); });"]}}]
        },
        {
          "name": "Create Payment - Idempotency Conflict Setup",
          "request": {
            "description": "Run this request first to create the original payment for idempotency conflict testing. Then run Create Payment - Idempotency Conflict.",
            "method": "POST",
            "header": [
              {"key": "Authorization", "value": "Bearer {{jwtToken}}"},
              {"key": "Idempotency-Key", "value": "{{conflictIdempotencyKey}}"},
              {"key": "X-Correlation-ID", "value": "{{correlationId}}"},
